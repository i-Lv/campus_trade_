ANA;AAOA,QAAA,UAAA,EAAA,IAPA;AAQA,QAAA,SAAA,EAAA;AARA,OAJA;AAcA,MAAA,gBAAA,EAAA,EAdA;AAeA,MAAA,cAAA,EAAA,EAfA;AAgBA,MAAA,aAAA,EAAA,KAhBA;AAiBA,MAAA,SAAA,EAAA,EAjBA;AAkBA,MAAA,YAAA,EAAA,EAlBA;AAmBA,MAAA,QAAA,EAAA,EAnBA;AAoBA,MAAA,cAAA,EAAA;AACA,WAAA,IADA;AAEA,WAAA,IAFA;AAGA,YAAA;AAHA;AApBA,KAAA;AA0BA,GA9BA;;AA+BA,EAAA,QAAA,EAAA;AACA,IAAA,YAAA,GAAA;AACA,UAAA,KAAA,QAAA,KAAA,EAAA,EAAA,OAAA,KAAA;AACA,aAAA,GAAA,KAAA,QAAA,IAAA;AACA;;AAJA,GA/BA;;AAqCA,EAAA,OAAA,GAAA;AACA,SAAA,iBAAA;AACA,GAvCA;;AAwCA,EAAA,OAAA,EAAA;AACA,UAAA,WAAA,GAAA;AACA,UAAA,CAAA,KAAA,YAAA,EAAA,EAAA;AAEA,WAAA,UAAA,GAAA,IAAA;AACA,WAAA,OAAA,CAAA,SAAA,GAAA,KAAA,SAAA,CAAA,IAAA,CAAA,GAAA,CAAA;AACA,WAAA,OAAA,CAAA,QAAA,GAAA,KAAA,QAAA;AACA,WAAA,OAAA,CAAA,SAAA,GAAA,KAAA,SAAA;;AAEA,UAAA;AACA,cAAA,GAAA,GAAA,MAAA,KAAA,MAAA,CAAA,IAAA,CAAA,eAAA,EAAA,KAAA,OAAA,CAAA;;AACA,YAAA,GAAA,CAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,OAAA,CAAA,OAAA,CAAA;AACA,YAAA,KAAA,EAAA,MADA;AAEA,YAAA,OAAA,EAAA,GAAA,CAAA,IAAA,CAAA,GAFA;AAGA,YAAA,QAAA,EAAA;AAHA,WAAA;AAKA,eAAA,OAAA,CAAA,IAAA,CAAA,YAAA;AACA;AACA,OAVA,CAUA,OAAA,KAAA,EAAA;AACA,aAAA,OAAA,CAAA,KAAA,CAAA;AACA,UAAA,KAAA,EAAA,MADA;AAEA,UAAA,OAAA,EAAA,KAAA,CAAA,OAAA,IAAA,SAFA;AAGA,UAAA,QAAA,EAAA;AAHA,SAAA;AAKA,QAAA,OAAA,CAAA,KAAA,CAAA,SAAA,EAAA,KAAA;AACA,OAjBA,SAiBA;AACA,aAAA,UAAA,GAAA,KAAA;AACA;AACA,KA7BA;;AA+BA,IAAA,YAAA,GAAA;AACA,UAAA,CAAA,KAAA,OAAA,CAAA,IAAA,EAAA;AACA,aAAA,OAAA,CAAA,OAAA,CAAA;AACA,UAAA,KAAA,EAAA,IADA;AAEA,UAAA,OAAA,EAAA,SAFA;AAGA,UAAA,QAAA,EAAA;AAHA,SAAA;AAKA,eAAA,KAAA;AACA;;AAEA,UAAA,CAAA,KAAA,OAAA,CAAA,KAAA,IAAA,KAAA,CAAA,KAAA,OAAA,CAAA,KAAA,CAAA,EAAA;AACA,aAAA,OAAA,CAAA,OAAA,CAAA;AACA,UAAA,KAAA,EAAA,IADA;AAEA,UAAA,OAAA,EAAA,YAFA;AAGA,UAAA,QAAA,EAAA;AAHA,SAAA;AAKA,eAAA,KAAA;AACA;;AAEA,UAAA,KAAA,SAAA,CAAA,MAAA,KAAA,CAAA,EAAA;AACA,aAAA,OAAA,CAAA,OAAA,CAAA;AACA,UAAA,KAAA,EAAA,IADA;AAEA,UAAA,OAAA,EAAA,SAFA;AAGA,UAAA,QAAA,EAAA;AAHA,SAAA;AAKA,eAAA,KAAA;AACA;;AAEA,UAAA,CAAA,KAAA,OAAA,CAAA,UAAA,EAAA;AACA,aAAA,OAAA,CAAA,OAAA,CAAA;AACA,UAAA,KAAA,EAAA,IADA;AAEA,UAAA,OAAA,EAAA,SAFA;AAGA,UAAA,QAAA,EAAA;AAHA,SAAA;AAKA,eAAA,KAAA;AACA;;AAEA,aAAA,IAAA;AACA,KArEA;;AAuEA,IAAA,SAAA,CAAA,MAAA,EAAA;AACA,WAAA,OAAA,CAAA,MAAA,GAAA,MAAA;AACA,KAzEA;;AA2EA,IAAA,aAAA,CAAA,QAAA,EAAA;AACA,WAAA,gBAAA,GAAA,QAAA;AACA,WAAA,OAAA,CAAA,UAAA,GAAA,QAAA,CAAA,EAAA;AACA,KA9EA;;AAgFA,UAAA,iBAAA,GAAA;AACA,UAAA;AACA,cAAA,GAAA,GAAA,MAAA,KAAA,MAAA,CAAA,IAAA,CAAA,iBAAA,EAAA,EAAA,CAAA;;AACA,YAAA,GAAA,CAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,YAAA,GAAA,GAAA,CAAA,IAAA,CAAA,IAAA;;AACA,cAAA,KAAA,YAAA,CAAA,MAAA,GAAA,CAAA,EAAA;AACA,iBAAA,aAAA,CAAA,KAAA,YAAA,CAAA,CAAA,CAAA;AACA;AACA;AACA,OARA,CAQA,OAAA,KAAA,EAAA;AACA,QAAA,OAAA,CAAA,KAAA,CAAA,aAAA,EAAA,KAAA;AACA;AACA,KA5FA;;AA8FA,IAAA,YAAA,GAAA;AACA,WAAA,OAAA,CAAA,QAAA,GAAA,KAAA,QAAA;AACA,KAhGA;;AAkGA,IAAA,qBAAA,GAAA;AACA,WAAA,OAAA,CAAA,SAAA,GAAA,KAAA,SAAA;AACA,KApGA;;AAsGA,IAAA,wBAAA,CAAA,IAAA,EAAA;AACA,WAAA,SAAA,CAAA,IAAA,CAAA,IAAA,CAAA,IAAA;AACA,KAxGA;;AA0GA,IAAA,YAAA,CAAA,IAAA,EAAA,QAAA,EAAA;AACA,WAAA,SAAA,GAAA,QAAA,CAAA,GAAA,CAAA,CAAA,IAAA,CAAA,CAAA,QAAA,GAAA,CAAA,CAAA,QAAA,CAAA,IAAA,GAAA,CAAA,CAAA,GAAA,CAAA;AACA,KA5GA;;AA8GA,IAAA,wBAAA,CAAA,IAAA,EAAA;AACA,WAAA,cAAA,GAAA,IAAA,CAAA,GAAA,IAAA,IAAA,CAAA,QAAA,IAAA,IAAA,CAAA,QAAA,CAAA,IAAA;AACA,WAAA,aAAA,GAAA,IAAA;AACA;;AAjHA;AAxCA,CAAA","sourcesContent":["<template>\r\n    <div class=\"product-publish-container\">\r\n      <!-- 主标题 -->\r\n      <h1 class=\"publish-title\">发布商品</h1>\r\n      \r\n      <!-- 两栏布局 -->\r\n      <div class=\"publish-layout\">\r\n        <!-- 左侧表单区域 -->\r\n        <div class=\"form-section\">\r\n          <!-- 商品基本信息卡片 -->\r\n          <div class=\"form-card\">\r\n            <h2 class=\"card-title\">商品基本信息</h2>\r\n            \r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">商品名称</label>\r\n              <el-input \r\n                v-model=\"product.name\" \r\n                placeholder=\"请输入商品名称\" \r\n                class=\"form-input\"\r\n                clearable\r\n              ></el-input>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">商品价格</label>\r\n              <el-input \r\n                v-model=\"product.price\" \r\n                placeholder=\"请输入商品价格\" \r\n                class=\"form-input\"\r\n                clearable\r\n              >\r\n                <template slot=\"prepend\">¥</template>\r\n              </el-input>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">新旧程度</label>\r\n              <div class=\"condition-slider\">\r\n                <el-slider\r\n                  v-model=\"oldLevel\"\r\n                  :min=\"1\"\r\n                  :max=\"10\"\r\n                  :marks=\"conditionMarks\"\r\n                  show-stops\r\n                  @change=\"handleChange\"\r\n                ></el-slider>\r\n                <div class=\"condition-value\">{{ oldLevelText }}</div>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">商品库存</label>\r\n              <el-input-number \r\n                v-model=\"inventory\" \r\n                :min=\"1\" \r\n                :max=\"10000\" \r\n                @change=\"handleInventoryChange\"\r\n                class=\"inventory-input\"\r\n              ></el-input-number>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">是否支持砍价</label>\r\n              <el-switch \r\n                v-model=\"product.isBargain\" \r\n                active-text=\"支持砍价\" \r\n                inactive-text=\"不支持砍价\"\r\n                active-color=\"#13ce66\"\r\n              ></el-switch>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 商品分类卡片 -->\r\n          <div class=\"form-card\">\r\n            <h2 class=\"card-title\">商品分类</h2>\r\n            <div class=\"category-tags\">\r\n              <el-tag\r\n                v-for=\"(category, index) in categoryList\"\r\n                :key=\"index\"\r\n                :type=\"categorySelected.id === category.id ? '' : 'info'\"\r\n                @click=\"categoryClick(category)\"\r\n                class=\"category-tag\"\r\n              >\r\n                {{ category.name }}\r\n              </el-tag>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 右侧上传和编辑区域 -->\r\n        <div class=\"upload-section\">\r\n          <!-- 图片上传卡片 -->\r\n          <div class=\"upload-card\">\r\n            <h2 class=\"card-title\">商品图片</h2>\r\n            <p class=\"upload-tip\">建议上传1:1比例的图片，最多9张</p>\r\n            \r\n            <el-upload \r\n              action=\"http://localhost:21090/api/campus-product-sys/v1.0/file/upload\"\r\n              list-type=\"picture-card\"\r\n              :limit=\"9\"\r\n              :on-success=\"handlePictureCardSuccess\"\r\n              :on-preview=\"handlePictureCardPreview\"\r\n              :on-remove=\"handleRemove\"\r\n              :file-list=\"fileList\"\r\n              class=\"image-uploader\"\r\n            >\r\n              <i class=\"el-icon-plus\"></i>\r\n            </el-upload>\r\n            \r\n            <el-dialog :visible.sync=\"dialogVisible\">\r\n              <img width=\"100%\" :src=\"dialogImageUrl\" alt=\"\">\r\n            </el-dialog>\r\n          </div>\r\n          \r\n          <!-- 商品详情编辑器 -->\r\n          <div class=\"editor-card\">\r\n            <h2 class=\"card-title\">商品详情</h2>\r\n            <Editor \r\n              height=\"400px\" \r\n              :receiveContent=\"product.detail\" \r\n              @on-receive=\"onReceive\" \r\n            />\r\n          </div>\r\n          \r\n          <!-- 发布按钮 -->\r\n          <el-button \r\n            type=\"primary\" \r\n            @click=\"postProduct\" \r\n            class=\"publish-button\"\r\n            :loading=\"publishing\"\r\n          >\r\n            立即发布\r\n          </el-button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import Editor from \"@/components/Editor\"\r\n  \r\n  export default {\r\n    components: { Editor },\r\n    name: 'PostProduct',\r\n    data() {\r\n      return {\r\n        oldLevel: 9,\r\n        inventory: 1,\r\n        publishing: false,\r\n        product: {\r\n          name: '',\r\n          price: '',\r\n          oldLevel: 9,\r\n          inventory: 1,\r\n          isBargain: false,\r\n          detail: '',\r\n          categoryId: null,\r\n          coverList: []\r\n        },\r\n        categorySelected: {},\r\n        dialogImageUrl: '',\r\n        dialogVisible: false,\r\n        coverList: [],\r\n        categoryList: [],\r\n        fileList: [],\r\n        conditionMarks: {\r\n          1: '全新',\r\n          5: '一般',\r\n          10: '旧物'\r\n        }\r\n      }\r\n    },\r\n    computed: {\r\n      oldLevelText() {\r\n        if (this.oldLevel === 10) return '十成新';\r\n        return `${this.oldLevel}成新`;\r\n      }\r\n    },\r\n    created() {\r\n      this.fetchCategoryList();\r\n    },\r\n    methods: {\r\n      async postProduct() {\r\n        if (!this.validateForm()) return;\r\n        \r\n        this.publishing = true;\r\n        this.product.coverList = this.coverList.join(',');\r\n        this.product.oldLevel = this.oldLevel;\r\n        this.product.inventory = this.inventory;\r\n        \r\n        try {\r\n          const res = await this.$axios.post('/product/save', this.product);\r\n          if (res.data.code === 200) {\r\n            this.$notify.success({\r\n              title: '发布成功',\r\n              message: res.data.msg,\r\n              duration: 2000\r\n            });\r\n            this.$router.push('/myProduct');\r\n          }\r\n        } catch (error) {\r\n          this.$notify.error({\r\n            title: '发布失败',\r\n            message: error.message || '发布商品时出错',\r\n            duration: 2000\r\n          });\r\n          console.error(\"新增商品异常:\", error);\r\n        } finally {\r\n          this.publishing = false;\r\n        }\r\n      },\r\n      \r\n      validateForm() {\r\n        if (!this.product.name) {\r\n          this.$notify.warning({\r\n            title: '提示',\r\n            message: '请输入商品名称',\r\n            duration: 1500\r\n          });\r\n          return false;\r\n        }\r\n        \r\n        if (!this.product.price || isNaN(this.product.price)) {\r\n          this.$notify.warning({\r\n            title: '提示',\r\n            message: '请输入有效的商品价格',\r\n            duration: 1500\r\n          });\r\n          return false;\r\n        }\r\n        \r\n        if (this.coverList.length === 0) {\r\n          this.$notify.warning({\r\n            title: '提示',\r\n            message: '请上传商品图片',\r\n            duration: 1500\r\n          });\r\n          return false;\r\n        }\r\n        \r\n        if (!this.product.categoryId) {\r\n          this.$notify.warning({\r\n            title: '提示',\r\n            message: '请选择商品分类',\r\n            duration: 1500\r\n          });\r\n          return false;\r\n        }\r\n        \r\n        return true;\r\n      },\r\n      \r\n      onReceive(detail) {\r\n        this.product.detail = detail;\r\n      },\r\n      \r\n      categoryClick(category) {\r\n        this.categorySelected = category;\r\n        this.product.categoryId = category.id;\r\n      },\r\n      \r\n      async fetchCategoryList() {\r\n        try {\r\n          const res = await this.$axios.post('/category/query', {});\r\n          if (res.data.code === 200) {\r\n            this.categoryList = res.data.data;\r\n            if (this.categoryList.length > 0) {\r\n              this.categoryClick(this.categoryList[0]);\r\n            }\r\n          }\r\n        } catch (error) {\r\n          console.error(\"查询商品类别信息异常:\", error);\r\n        }\r\n      },\r\n      \r\n      handleChange() {\r\n        this.product.oldLevel = this.oldLevel;\r\n      },\r\n      \r\n      handleInventoryChange() {\r\n        this.product.inventory = this.inventory;\r\n      },\r\n      \r\n      handlePictureCardSuccess(file) {\r\n        this.coverList.push(file.data);\r\n      },\r\n      \r\n      handleRemove(file, fileList) {\r\n        this.coverList = fileList.map(f => f.response ? f.response.data : f.url);\r\n      },\r\n      \r\n      handlePictureCardPreview(file) {\r\n        this.dialogImageUrl = file.url || (file.response && file.response.data);\r\n        this.dialogVisible = true;\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n  \r\n  <style scoped lang=\"scss\">\r\n  .product-publish-container {\r\n    max-width: 1200px;\r\n    margin: 0 auto;\r\n    padding: 20px;\r\n    \r\n    .publish-title {\r\n      font-size: 24px;\r\n      color: #333;\r\n      margin-bottom: 30px;\r\n      text-align: center;\r\n      font-weight: 600;\r\n    }\r\n    \r\n    .publish-layout {\r\n      display: flex;\r\n      gap: 20px;\r\n      \r\n      .form-section {\r\n        flex: 1;\r\n        min-width: 400px;\r\n      }\r\n      \r\n      .upload-section {\r\n        flex: 1;\r\n        min-width: 400px;\r\n      }\r\n    }\r\n    \r\n    .form-card, .upload-card, .editor-card {\r\n      background-color: #fff;\r\n      border-radius: 12px;\r\n      padding: 20px;\r\n      margin-bottom: 20px;\r\n      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);\r\n      \r\n      .card-title {\r\n        font-size: 18px;\r\n        color: #333;\r\n        margin-bottom: 20px;\r\n        font-weight: 600;\r\n        position: relative;\r\n        padding-left: 10px;\r\n        \r\n        &::before {\r\n          content: '';\r\n          position: absolute;\r\n          left: 0;\r\n          top: 4px;\r\n          height: 16px;\r\n          width: 4px;\r\n          background-color: #409EFF;\r\n          border-radius: 2px;\r\n        }\r\n      }\r\n    }\r\n    \r\n    .form-group {\r\n      margin-bottom: 20px;\r\n      \r\n      .form-label {\r\n        display: block;\r\n        font-size: 14px;\r\n        color: #606266;\r\n        margin-bottom: 10px;\r\n        font-weight: 500;\r\n      }\r\n      \r\n      .form-input {\r\n        width: 100%;\r\n      }\r\n      \r\n      .condition-slider {\r\n        display: flex;\r\n        align-items: center;\r\n        gap: 20px;\r\n        \r\n        .el-slider {\r\n          flex: 1;\r\n        }\r\n        \r\n        .condition-value {\r\n          min-width: 60px;\r\n          text-align: center;\r\n          font-size: 14px;\r\n          color: #409EFF;\r\n          font-weight: 500;\r\n        }\r\n      }\r\n      \r\n      .inventory-input {\r\n        width: 150px;\r\n      }\r\n    }\r\n    \r\n    .category-tags {\r\n      display: flex;\r\n      flex-wrap: wrap;\r\n      gap: 10px;\r\n      \r\n      .category-tag {\r\n        cursor: pointer;\r\n        transition: all 0.3s;\r\n        padding: 0 20px;\r\n        height: 32px;\r\n        line-height: 32px;\r\n        \r\n        &:hover {\r\n          transform: translateY(-2px);\r\n          box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\r\n        }\r\n      }\r\n    }\r\n    \r\n    .upload-tip {\r\n      font-size: 12px;\r\n      color: #909399;\r\n      margin-bottom: 15px;\r\n    }\r\n    \r\n    .editor-card {\r\n      min-height: 500px;\r\n    }\r\n    \r\n    .publish-button {\r\n      width: 100%;\r\n      height: 50px;\r\n      font-size: 16px;\r\n      margin-top: 20px;\r\n      border-radius: 8px;\r\n      background: linear-gradient(90deg, #409EFF, #66b1ff);\r\n      border: none;\r\n      box-shadow: 0 4px 12px rgba(64, 158, 255, 0.3);\r\n      transition: all 0.3s;\r\n      \r\n      &:hover {\r\n        transform: translateY(-2px);\r\n        box-shadow: 0 6px 16px rgba(64, 158, 255, 0.4);\r\n      }\r\n      \r\n      &:active {\r\n        transform: translateY(0);\r\n      }\r\n    }\r\n  }\r\n  \r\n  /* 使用全局样式替代/deep/ */\r\n  .image-uploader ::v-deep .el-upload {\r\n    width: 100px;\r\n    height: 100px;\r\n    line-height: 100px;\r\n    border: 1px dashed #d9d9d9;\r\n    border-radius: 6px;\r\n    transition: all 0.3s;\r\n    \r\n    &:hover {\r\n      border-color: #409EFF;\r\n    }\r\n  }\r\n  \r\n  @media (max-width: 992px) {\r\n    .publish-layout {\r\n      flex-direction: column;\r\n      \r\n      .form-section, .upload-section {\r\n        min-width: 100% !important;\r\n      }\r\n    }\r\n  }\r\n  </style>"],"sourceRoot":"src/views/user"}]}