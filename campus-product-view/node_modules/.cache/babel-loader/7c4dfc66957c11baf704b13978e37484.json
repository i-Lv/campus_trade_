{"remainingRequest":"E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\babel-loader\\lib\\index.js!E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\src\\views\\user\\Search.vue?vue&type=script&lang=js&","dependencies":[{"path":"E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\src\\views\\user\\Search.vue","mtime":1745138054000},{"path":"E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1767685780711},{"path":"E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\babel-loader\\lib\\index.js","mtime":1767685781392},{"path":"E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1767685780711},{"path":"E:\\Java\\IntelliJ IDEA 2025.2.1\\ideaproject\\campus_trade\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js","mtime":1767685774490}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Search.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiCA,SAAA,YAAA,QAAA,iBAAA;AACA,eAAA;AACA,EAAA,IAAA,GAAA;AACA,WAAA;AACA,MAAA,SAAA,EAAA,EADA;AAEA,MAAA,WAAA,EAAA,IAFA;AAEA;AACA,MAAA,eAAA,EAAA,EAHA;AAIA,MAAA,WAAA,EAAA;AAJA,KAAA;AAMA,GARA;;AASA,EAAA,OAAA,GAAA;AACA,SAAA,cAAA,GADA,CACA;AACA,GAXA;;AAYA,EAAA,aAAA,GAAA;AACA,SAAA,cAAA,GADA,CACA;AACA,GAdA;;AAeA,EAAA,OAAA,EAAA;AACA,IAAA,KAAA,CAAA,OAAA,EAAA;AACA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,+BAAA,OAAA,CAAA,EAAA;AACA,KAJA;;AAKA,IAAA,cAAA,CAAA,OAAA,EAAA;AACA,UAAA,OAAA,CAAA,SAAA,KAAA,IAAA,EAAA;AACA;AACA;;AACA,YAAA,YAAA,GAAA,OAAA,CAAA,SAAA,CAAA,KAAA,CAAA,GAAA,CAAA;AACA,aAAA,YAAA,CAAA,CAAA,CAAA;AACA,KAXA;;AAYA,IAAA,YAAA,GAAA;AACA,WAAA,eAAA,CAAA,IAAA,GAAA,KAAA,SAAA;AACA,WAAA,MAAA,CAAA,IAAA,CAAA,gBAAA,EAAA,KAAA,eAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA,CADA,CACA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,WAAA,GAAA,IAAA,CAAA,IAAA;AACA;AACA,OALA,EAKA,KALA,CAKA,KAAA,IAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,SAAA,EAAA,KAAA;AACA,OAPA;AAQA,KAtBA;;AAuBA,IAAA,OAAA,GAAA;AACA,YAAA,GAAA,GAAA,YAAA,EAAA;;AACA,UAAA,GAAA,KAAA,KAAA,SAAA,EAAA;AACA,aAAA,SAAA,GAAA,GAAA;AACA,aAAA,YAAA;AACA;AACA,KA7BA;;AA8BA,IAAA,cAAA,GAAA;AACA;AACA,WAAA,WAAA,GAAA,WAAA,CAAA,MAAA;AACA,aAAA,OAAA;AACA,OAFA,EAEA,IAFA,CAAA,CAFA,CAIA;AACA,KAnCA;;AAoCA,IAAA,cAAA,GAAA;AACA;AACA,UAAA,KAAA,WAAA,EAAA;AACA,QAAA,aAAA,CAAA,KAAA,WAAA,CAAA;AACA,aAAA,WAAA,GAAA,IAAA,CAFA,CAEA;AACA;AACA;;AA1CA;AAfA,CAAA","sourcesContent":["<template>\r\n    <div class=\"product-list\">\r\n        <el-row v-if=\"productList.length === 0\">\r\n            <el-empty description=\"暂无商品信息\"></el-empty>\r\n        </el-row>\r\n        <el-row v-else>\r\n            <el-col :span=\"6\" @click.native=\"route(product)\" v-for=\"(product, index) in productList\" :key=\"index\">\r\n                <div class=\"item-product\">\r\n                    <div class=\"cover\">\r\n                        <img :src=\"coverListParse(product)\" alt=\"\" srcset=\"\">\r\n                    </div>\r\n                    <div style=\"display: flex;justify-content: left;gap: 4px;align-items: center;\">\r\n                        <span class=\"bargain-hover\">{{ product.isBargain ? '支持砍价' : '不支持砍价' }}</span>\r\n                        <span class=\"title\">\r\n                            {{ product.name }}\r\n                        </span>\r\n                    </div>\r\n                    <div style=\"padding-block: 15px;\">\r\n                        <span class=\"decimel-symbol\">¥</span>\r\n                        <span class=\"price\">{{ product.price }}</span>\r\n                        <span class=\"love\">4人想要</span>\r\n                    </div>\r\n                    <div class=\"info\">\r\n                        <img :src=\"product.userAvatar\" alt=\"\" srcset=\"\">\r\n                        <span>{{ product.userName }}</span>\r\n                    </div>\r\n                </div>\r\n            </el-col>\r\n        </el-row>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport { getSearchKey } from \"@/utils/storage\";\r\nexport default {\r\n    data() {\r\n        return {\r\n            searchKey: '',\r\n            keyInterval: null, // 用于存储定时器的引用\r\n            productQueryDto: {},\r\n            productList: []\r\n        };\r\n    },\r\n    created() {\r\n        this.startKeyLoader(); // 启动定时器\r\n    },\r\n    beforeDestroy() {\r\n        this.clearKeyLoader(); // 清除定时器\r\n    },\r\n    methods: {\r\n        route(product) {\r\n            // 跳转商品详情\r\n            this.$router.push('/product-detail?productId=' + product.id);\r\n        },\r\n        coverListParse(product) {\r\n            if (product.coverList === null) {\r\n                return;\r\n            }\r\n            const newCoverList = product.coverList.split(',');\r\n            return newCoverList[0];\r\n        },\r\n        fetchProduct() {\r\n            this.productQueryDto.name = this.searchKey;\r\n            this.$axios.post('/product/query', this.productQueryDto).then(res => {\r\n                const { data } = res; // 解构\r\n                if (data.code === 200) {\r\n                    this.productList = data.data;\r\n                }\r\n            }).catch(error => {\r\n                console.log(\"商品查询异常：\", error);\r\n            })\r\n        },\r\n        loadKey() {\r\n            const key = getSearchKey();\r\n            if (key !== this.searchKey) {\r\n                this.searchKey = key;\r\n                this.fetchProduct();\r\n            }\r\n        },\r\n        startKeyLoader() {\r\n            // 每隔一定时间调用 loadKey 方法\r\n            this.keyInterval = setInterval(() => {\r\n                this.loadKey();\r\n            }, 1000); // 每1000毫秒（1秒）调用一次\r\n        },\r\n        clearKeyLoader() {\r\n            // 清除定时器\r\n            if (this.keyInterval) {\r\n                clearInterval(this.keyInterval);\r\n                this.keyInterval = null; // 重置定时器引用\r\n            }\r\n        }\r\n    }\r\n};\r\n</script>\r\n<style lang=\"scss\" scope>\r\n.product-list {\r\n    padding-block: 20px;\r\n\r\n    .item-product {\r\n        padding: 10px 10px 16px 10px;\r\n        box-sizing: border-box;\r\n        border-radius: 15px;\r\n        transition: all .5s;\r\n        cursor: pointer;\r\n\r\n        .cover {\r\n            img {\r\n                width: 100%;\r\n                height: 240px;\r\n                border-radius: 10px;\r\n            }\r\n        }\r\n\r\n        .bargain-hover {\r\n            font-size: 12px;\r\n            font-weight: 800;\r\n            background-color: rgb(255, 230, 15);\r\n            color: rgb(51, 51, 51);\r\n            border-radius: 2px;\r\n            padding: 2px 6px;\r\n        }\r\n\r\n        .title {\r\n            font-size: 20px;\r\n            color: #1f1f1f;\r\n            width: 120px;\r\n            white-space: nowrap;\r\n            overflow: hidden;\r\n            text-overflow: ellipsis;\r\n        }\r\n\r\n        .decimel-symbol {\r\n            font-size: 14px;\r\n            color: #ff4f24;\r\n            font-weight: 800;\r\n        }\r\n\r\n        .price {\r\n            font-size: 24px;\r\n            color: #ff4f24;\r\n            font-weight: 800;\r\n            margin-right: 6px;\r\n        }\r\n\r\n        .love {\r\n            font-size: 14px;\r\n            color: #999;\r\n        }\r\n\r\n        .info {\r\n            display: flex;\r\n            justify-content: left;\r\n            align-items: center;\r\n            gap: 4px;\r\n\r\n            img {\r\n                width: 20px;\r\n                height: 20px;\r\n                border-radius: 50%;\r\n            }\r\n\r\n            span {\r\n                font-size: 14px;\r\n                color: #999;\r\n            }\r\n        }\r\n\r\n\r\n    }\r\n\r\n    .item-product:hover {\r\n        box-shadow: 1px 4px 6px rgba(0, 0, 0, 0.1), 0 1px 3px rgba(0, 0, 0, 0.06);\r\n    }\r\n}\r\n</style>\r\n"],"sourceRoot":"src/views/user"}]}